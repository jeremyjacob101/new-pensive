{
  "name": "codebase-pensive",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --config config/vite.config.ts",
    "build": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p config/tsconfig.node.json && vite build --config config/vite.config.ts",
    "lint": "eslint .",
    "format": "prettier --ignore-path config/.prettierignore --cache --write \"**/*.{js,jsx,cjs,mjs,ts,tsx,cts,mts}\"",
    "format:check": "prettier --ignore-path config/.prettierignore --check \"**/*.{js,jsx,cjs,mjs,ts,tsx,cts,mts}\"",
    "preview": "vite preview --config config/vite.config.ts"
  },
  "prettier": {
    "plugins": [
      "./config/prettier-plugin-single-line-imports.mjs"
    ],
    "singleLineImports": true,
    "sortTopImportsByLength": true,
    "overrides": [
      {
        "files": [
          "**/*.{js,jsx,cjs,mjs}"
        ],
        "options": {
          "parser": "imports-babel"
        }
      },
      {
        "files": [
          "**/*.{ts,tsx,cts,mts}"
        ],
        "options": {
          "parser": "imports-typescript"
        }
      }
    ]
  },
  "dependencies": {
    "@auth/core": "^0.37.0",
    "@convex-dev/auth": "^0.0.92",
    "csv-parse": "^6.2.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "convex": "^1.38.0",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "prettier": "^3.8.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
